# =============================================================
# shoutrrr-logger — environment variable reference
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# =============================================================

# ------------------------------------------------------------
# Database (REQUIRED)
# PostgreSQL 17 connection string.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:CHANGEME@localhost:5432/shoutrrr_logger

# Convenience variable used by the docker-compose postgres service.
# Must match the password in DATABASE_URL above.
POSTGRES_PASSWORD=CHANGEME

# SQLAlchemy connection pool size and overflow, *per worker process* (see
# WORKERS below). Each gunicorn worker opens its own pool, so the total
# connections this app can open to PostgreSQL is approximately:
#   WORKERS * (DB_POOL_SIZE + DB_MAX_OVERFLOW)
# Defaults (5 + 5) * WORKERS=4 = 40, comfortably under PostgreSQL's default
# `max_connections` of 100. Raise these only if you've also raised
# `max_connections` and have headroom for other clients (migrations, admin
# tools, etc.).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# ------------------------------------------------------------
# OpenID Connect (REQUIRED)
# ------------------------------------------------------------

# Full URL to the provider's OpenID discovery document.
# Keycloak:         https://keycloak.example.com/realms/<realm>/.well-known/openid-configuration
# Auth0:            https://<tenant>.auth0.com/.well-known/openid-configuration
# Authentik:        https://authentik.example.com/application/o/<slug>/.well-known/openid-configuration
# Okta:             https://<tenant>.okta.com/oauth2/default/.well-known/openid-configuration
# Microsoft Entra:  https://login.microsoftonline.com/<tenant>/v2.0/.well-known/openid-configuration
OIDC_DISCOVERY_URL=

# Client ID registered with your OIDC provider.
OIDC_CLIENT_ID=shoutrrr-logger

# Client secret from your OIDC provider (confidential client). REQUIRED.
OIDC_CLIENT_SECRET=

# Public base URL of this application — must match the redirect URI registered
# with your OIDC provider exactly (no trailing slash).
# Development (no reverse proxy): http://localhost:4000
# Production (behind the bundled nginx reverse proxy, see NGINX_SERVER_NAME
# below): https://<NGINX_SERVER_NAME>, no port — nginx terminates TLS on 443.
APP_BASE_URL=http://localhost:4000

# ------------------------------------------------------------
# Role mapping
# Roles are read from the OIDC access token on every login.
# The application automatically checks both:
#   1. The path defined by OIDC_ROLES_CLAIM (realm roles)
#   2. resource_access.<OIDC_CLIENT_ID>.roles (Keycloak client roles)
# ------------------------------------------------------------

# Dot-separated path into the token claims for realm-level roles.
# Default works for Keycloak realm roles. Change for other providers:
#   Auth0 / Authentik / Entra flat claim:  roles
#   Okta groups:                            groups
OIDC_ROLES_CLAIM=realm_access.roles

# The role string that grants read-only access to /log.
OIDC_ROLE_VIEWER=viewer

# The role string that grants full access including /admin.
OIDC_ROLE_ADMIN=admin

# Space-separated OAuth2 scopes requested at login.
# "roles" is required for Keycloak to include role claims in the token.
OIDC_SCOPES=openid email profile roles

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# Secret key used to sign session JWTs. Generate with:
#   openssl rand -base64 32
SECRET_KEY=

# Number of Gunicorn/Uvicorn worker processes.
WORKERS=4

# Internal URL the Next.js frontend uses to reach the FastAPI backend.
# In Docker (single container): http://localhost:9000
# Override only if running frontend and backend as separate services.
BACKEND_URL=http://localhost:9000

# ------------------------------------------------------------
# Reverse proxy (nginx, REQUIRED for docker-compose)
#
# docker-compose runs an nginx container as the only externally-reachable
# service. It terminates TLS and routes /api/* to the FastAPI backend and
# everything else to the Next.js frontend — the app and database containers
# are not published to the host.
# ------------------------------------------------------------

# Public hostname this app is served under (no scheme, no port). Used as the
# nginx server_name AND to locate the TLS certificate/key, which must already
# exist on the host at:
#   /etc/ssl/certs/<NGINX_SERVER_NAME>.crt
#   /etc/ssl/private/<NGINX_SERVER_NAME>.key
NGINX_SERVER_NAME=shoutrrr-logger.example.com
