{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "generic": {
      "format": "%(asctime)s [%(process)d] [%(levelname)s] [%(name)s] %(message)s",
      "datefmt": "[%Y-%m-%d %H:%M:%S %z]",
      "class": "logging.Formatter"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "generic",
      "stream": "ext://sys.stdout"
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["console"]
  },
  "loggers": {
    "gunicorn.error": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    },
    "gunicorn.access": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    }
  }
}
