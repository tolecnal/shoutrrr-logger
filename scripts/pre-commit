#!/usr/bin/env bash
# Auto-format staged backend Python files with ruff before every commit.
# Reformatted files are re-staged automatically so the commit includes them.

# Find ruff: prefer PATH, then common install locations (uv, pipx, mason)
if command -v ruff &>/dev/null; then
  RUFF=ruff
elif [[ -x ~/.local/bin/ruff ]]; then
  RUFF=~/.local/bin/ruff
elif [[ -x ~/.local/share/nvim/mason/bin/ruff ]]; then
  RUFF=~/.local/share/nvim/mason/bin/ruff
else
  echo "pre-commit: ruff not found — skipping backend format (install with: pip install ruff)" >&2
  exit 0
fi

# Collect staged .py files inside backend/ (excluding the build/ artefact dir)
mapfile -t PY_FILES < <(
  git diff --cached --name-only --diff-filter=ACM \
  | grep '^backend/.*\.py$' \
  | grep -v '^backend/build/'
)

if [[ ${#PY_FILES[@]} -eq 0 ]]; then
  exit 0
fi

"$RUFF" format "${PY_FILES[@]}"
"$RUFF" check --fix "${PY_FILES[@]}" 2>/dev/null || true

git add "${PY_FILES[@]}"
